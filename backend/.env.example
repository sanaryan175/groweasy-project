# AI Provider: ollama (local), groq (cloud), deepseek, opencode-zen, or gemini
AI_PROVIDER=opencode-zen

# OpenCode Zen (requires API key from https://opencode.ai)
# Free models: deepseek-v4-flash-free, mimo-v2.5-free, hy3-free, nemotron-3-ultra-free, north-mini-code-free
GROQ_API_URL=https://opencode.ai/zen/v1
GROQ_API_KEY=sk-your-key-here
GROQ_MODEL=north-mini-code-free

# DeepSeek (requires API key)
# GROQ_API_URL=https://api.deepseek.com/v1
# GROQ_API_KEY=sk-your-key-here
# GROQ_MODEL=deepseek-chat

# Groq (requires API key)
# GROQ_API_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=qwen/qwen3-32b

# Ollama (local - no API key needed)
# GROQ_API_URL=http://localhost:11434/v1
# GROQ_MODEL=qwen3.5:latest

# Processing (optional - defaults shown)
# GROQ_BATCH_SIZE=5
# GROQ_CONCURRENCY=5
# GROQ_TIMEOUT=60000

# Server
PORT=3001
